{
  "name": "petlibro-cards",
  "version": "0.3.0",
  "description": "Custom Home Assistant Lovelace card for PetLibro devices",
  "type": "module",
  "main": "dist/petlibro-cards.js",
  "scripts": {
    "build": "npm run lint && npm run rollup",
